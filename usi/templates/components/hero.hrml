<?component id="hero-cmp"?>
<?bind var="label"/?>
<?bind var="title"/?>
<?bind var="description"/?>
<section class="hero">
    <div class="hero-content">
        <?if cond="$label"?>
        <p class="hero-label">$label</p>
        <?/if?>
        <?if cond="$title"?>
        <h1 class="hero-title">$title</h1>
        <?/if?>
        <?if cond="$description"?>
        <p class="hero-description">$description</p>
        <?/if?>
    </div>
</section>
<?/component?>
