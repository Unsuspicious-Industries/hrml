                <?use id="card-cmp"?>
                    <?href?>/product<?/href?>
                    <?glyph?>◈<?/glyph?>
                    <?title?>Formal Verification<?/title?>
                    <?text?>Applying formal methods to verify correctness of software systems.<?/text?>
