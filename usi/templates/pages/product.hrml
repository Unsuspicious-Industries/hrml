                <?use id="card-cmp"?>
                    <?href?>/product<?/href?>
                    <?glyph?>⧉<?/glyph?>
                    <?title?>LLM Formal Constraints<?/title?>
                    <?text?>Training transformer models with type-theoretic constraints for more reliable code generation.<?/text?>
