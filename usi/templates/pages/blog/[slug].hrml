<?data from="data/posts/$slug.mdx" as="post"?>

<?block slot="content"?>
    <?use id="prose-page"?>
        <?bind var="label"?>Research Note<?/bind?>
        <?bind var="title" from="post.title"/?>
        <?bind var="description" from="post.excerpt"/?>
        <?bind var="meta"?><?get id="post.author"?> · <?get id="post.publishDate"?> · <?get id="post.status"?><?/bind?>
        <?block slot="content"?><?get id="post.body"?></?block?>
    </?use?>
</?block?>
